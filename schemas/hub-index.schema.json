{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hub-index.schema.json",
  "title": "Registry Hub Index",
  "description": "Schema for registry-hub hub-index.json - the aggregated index of all leaf registries",
  "type": "object",
  "required": ["hubVersion", "generatedAt", "totalItems", "registries", "items"],
  "properties": {
    "hubVersion": {
      "$ref": "shared/common.schema.json#/definitions/SemanticVersion"
    },
    "generatedAt": {
      "$ref": "shared/common.schema.json#/definitions/ISODateTime"
    },
    "totalItems": {
      "type": "integer",
      "minimum": 0
    },
    "registries": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RegistrySummary"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/IndexedItem"
      }
    }
  },
  "definitions": {
    "RegistrySummary": {
      "type": "object",
      "required": ["registryType", "repoUrl", "itemCount", "lastUpdated"],
      "properties": {
        "registryType": {
          "$ref": "shared/common.schema.json#/definitions/RegistryType"
        },
        "repoUrl": {
          "type": "string",
          "format": "uri"
        },
        "itemCount": {
          "type": "integer",
          "minimum": 0
        },
        "lastUpdated": {
          "$ref": "shared/common.schema.json#/definitions/ISODateTime"
        }
      }
    },
    "IndexedItem": {
      "type": "object",
      "required": ["canonicalId", "registryType", "name", "version", "description", "sourceRepo"],
      "properties": {
        "canonicalId": {
          "type": "string"
        },
        "registryType": {
          "$ref": "shared/common.schema.json#/definitions/RegistryType"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "$ref": "shared/common.schema.json#/definitions/SemanticVersion"
        },
        "description": {
          "type": "string"
        },
        "sourceRepo": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
